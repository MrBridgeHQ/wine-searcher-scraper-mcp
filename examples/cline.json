{
  "_comment": "Cline MCP configuration. In VS Code, open the Cline extension settings and add this to the MCP Servers section.",
  "mcpServers": {
    "wine-searcher": {
      "command": "npx",
      "args": [
        "-y",
        "@apify/actors-mcp-server",
        "--actors",
        "mrbridge/wine-searcher-scraper-from-list"
      ],
      "env": {
        "APIFY_TOKEN": "YOUR_APIFY_TOKEN_HERE"
      },
      "disabled": false,
      "autoApprove": []
    }
  }
}
